<%- include("partials/header") %>

<div class="row justify-content-center g-4">
  <div class="col-lg-5">
    <div class="card shadow-sm border-0">
      <img src="<%= comic.comic_url %>" class="card-img-top" alt="<%= comic.title %>">
      <div class="card-body">
        <h2 class="h5"><%= comic.title %></h2>
        <p class="text-muted mb-0"><%= comic.site_name %></p>
      </div>
    </div>
  </div>

  <div class="col-lg-7">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <h1 class="h3 mb-4">Add Comment</h1>

        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <% if (success) { %>
          <div class="alert alert-success"><%= success %></div>
        <% } %>

        <form method="POST" action="/addComment/<%= comic.comic_id %>">
          <div class="mb-3">
            <label class="form-label">Author</label>
            <input type="text" name="author" class="form-control" required>
          </div>

          <div class="mb-4">
            <label class="form-label">Comment</label>
            <textarea name="comment" rows="5" class="form-control" required></textarea>
          </div>

          <button type="submit" class="btn btn-primary">Save Comment</button>
          <a href="javascript:history.back()" class="btn btn-outline-secondary">Back</a>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include("partials/footer") %>