<%- include("partials/header") %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <h1 class="h3 mb-4">Add Comic</h1>

        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <% if (success) { %>
          <div class="alert alert-success"><%= success %></div>
        <% } %>

        <form method="POST" action="/addComic">
          <div class="mb-3">
            <label class="form-label">Comic Title</label>
            <input type="text" name="title" class="form-control" required>
          </div>

          <div class="mb-3">
            <label class="form-label">Date</label>
            <input type="date" name="comic_date" class="form-control" required>
          </div>

          <div class="mb-3">
            <label class="form-label">Comic Image URL</label>
            <input type="url" name="comic_url" class="form-control" placeholder="https://..." required>
          </div>

          <div class="mb-4">
            <label class="form-label">Web Site</label>
            <select name="site_id" class="form-select" required>
              <option value="">Select one...</option>
              <% sites.forEach(site => { %>
                <option value="<%= site.site_id %>"><%= site.site_name %></option>
              <% }) %>
            </select>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Add Comic</button>
            <a href="/" class="btn btn-outline-secondary">Back Home</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include("partials/footer") %>